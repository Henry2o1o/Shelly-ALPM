<?xml version="1.0" encoding="UTF-8"?>
<interface>
    <requires lib="gtk" version="4.0"/>
    <object class="GtkBox" id="SetupWindow">
        <property name="orientation">vertical</property>
        <property name="hexpand">true</property>
        <property name="vexpand">true</property>
        <property name="halign">fill</property>
        <property name="valign">fill</property>
        <style>
            <class name="background"/>
        </style>
        <child>
            <object class="GtkScrolledWindow">
                <property name="hscrollbar-policy">never</property>
                <property name="vexpand">true</property>
                <child>
                    <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">15</property>
                        <property name="margin-start">40</property>
                        <property name="margin-end">40</property>
                        <property name="margin-top">20</property>
                        <property name="margin-bottom">60</property>
                        <property name="halign">center</property>
                        <property name="width-request">600</property>
                        <child>
                            <object class="GtkBox">
                                <property name="orientation">horizontal</property>
                                <property name="spacing">25</property>
                                <property name="halign">center</property>
                                <child>
                                    <object class="GtkImage" id="intro_image">
                                        <property name="pixel-size">192</property>
                                        <property name="valign">center</property>
                                    </object>
                                </child>
                                <child>
                                    <object class="GtkBox">
                                        <property name="orientation">vertical</property>
                                        <property name="spacing">5</property>
                                        <property name="valign">center</property>
                                        <child>
                                            <object class="GtkLabel">
                                                <property name="label">Welcome to Shelly</property>
                                                <property name="halign">start</property>
                                                <style>
                                                    <class name="title-1"/>
                                                </style>
                                            </object>
                                        </child>
                                        <child>
                                            <object class="GtkLabel">
                                                <property name="label">Let's get you set up with some basic configurations.</property>
                                                <property name="wrap">true</property>
                                                <property name="halign">start</property>
                                                <style>
                                                    <class name="title-2"/>
                                                </style>
                                            </object>
                                        </child>
                                    </object>
                                </child>
                            </object>
                        </child>
                        <child>
                            <object class="GtkListBox">
                                <property name="selection-mode">none</property>
                                <property name="show-separators">true</property>
                                <style>
                                    <class name="boxed-list"/>
                                </style>
                                <child>
                                    <object class="GtkListBoxRow">
                                        <property name="activatable">false</property>
                                        <child>
                                            <object class="GtkBox">
                                                <property name="orientation">vertical</property>
                                                <property name="margin-start">15</property>
                                                <property name="margin-end">15</property>
                                                <property name="margin-top">15</property>
                                                <property name="margin-bottom">15</property>
                                                <property name="spacing">5</property>
                                                <child>
                                                    <object class="GtkCheckButton" id="aur_check">
                                                        <property name="label">AUR-Unterstützung aktivieren</property>
                                                        <property name="active">false</property>
                                                    </object>
                                                </child>
                                                <child>
                                                    <object class="GtkLabel">
                                                        <property name="label">Im Arch User Repository (AUR) findest du eine umfangreiche Sammlung von Community-gepflegten Paketen. Beachte jedoch, dass AUR-Pakete Schadsoftware enthalten können. Sei daher bei der Verwendung des AUR vorsichtig.</property>
                                                        <property name="wrap">true</property>
                                                        <property name="xalign">0</property>
                                                        <style>
                                                            <class name="body"/>
                                                            <class name="dim-label"/>
                                                        </style>
                                                    </object>
                                                </child>
                                            </object>
                                        </child>
                                    </object>
                                </child>
                                <child>
                                    <object class="GtkListBoxRow">
                                        <property name="activatable">false</property>
                                        <child>
                                            <object class="GtkBox">
                                                <property name="orientation">vertical</property>
                                                <property name="margin-start">15</property>
                                                <property name="margin-end">15</property>
                                                <property name="margin-top">15</property>
                                                <property name="margin-bottom">15</property>
                                                <property name="spacing">5</property>
                                                <child>
                                                    <object class="GtkCheckButton" id="flatpak_check">
                                                        <property name="label">Flatpak-Unterstützung aktivieren</property>
                                                        <property name="active">false</property>
                                                    </object>
                                                </child>
                                                <child>
                                                    <object class="GtkLabel">
                                                        <property name="label">Unterstützung für Flatpak-Anwendungen von Flathub und anderen Repositories aktivieren.</property>
                                                        <property name="wrap">true</property>
                                                        <property name="xalign">0</property>
                                                        <style>
                                                            <class name="body"/>
                                                            <class name="dim-label"/>
                                                        </style>
                                                    </object>
                                                </child>
                                            </object>
                                        </child>
                                    </object>
                                </child>
                                <child>
                                    <object class="GtkListBoxRow">
                                        <property name="activatable">false</property>
                                        <child>
                                            <object class="GtkBox">
                                                <property name="orientation">vertical</property>
                                                <property name="margin-start">15</property>
                                                <property name="margin-end">15</property>
                                                <property name="margin-top">15</property>
                                                <property name="margin-bottom">15</property>
                                                <property name="spacing">5</property>
                                                <child>
                                                    <object class="GtkCheckButton" id="appimage_check">
                                                        <property name="label">AppImage-Unterstützung aktivieren</property>
                                                        <property name="active">false</property>
                                                    </object>
                                                </child>
                                                <child>
                                                    <object class="GtkLabel">
                                                        <property name="label">Updates für AppImage-Anwendungen einfach verwalten und konfigurieren.</property>
                                                        <property name="wrap">true</property>
                                                        <property name="xalign">0</property>
                                                        <style>
                                                            <class name="body"/>
                                                            <class name="dim-label"/>
                                                        </style>
                                                    </object>
                                                </child>
                                            </object>
                                        </child>
                                    </object>
                                </child>
                                <child>
                                    <object class="GtkListBoxRow">
                                        <property name="activatable">false</property>
                                        <child>
                                            <object class="GtkBox">
                                                <property name="orientation">vertical</property>
                                                <property name="margin-start">15</property>
                                                <property name="margin-end">15</property>
                                                <property name="margin-top">15</property>
                                                <property name="margin-bottom">15</property>
                                                <property name="spacing">5</property>
                                                <child>
                                                    <object class="GtkCheckButton" id="tray_check">
                                                        <property name="label">Tray-Symbol aktivieren</property>
                                                        <property name="active">true</property>
                                                    </object>
                                                </child>
                                                <child>
                                                    <object class="GtkLabel">
                                                        <property name="label">Ein Statussymbol in deiner Taskleiste anzeigen, um schnellen Zugriff und Benachrichtigungen zu ermöglichen.</property>
                                                        <property name="wrap">true</property>
                                                        <property name="xalign">0</property>
                                                        <style>
                                                            <class name="body"/>
                                                            <class name="dim-label"/>
                                                        </style>
                                                    </object>
                                                </child>
                                            </object>
                                        </child>
                                    </object>
                                </child>
                            </object>
                        </child>
                        <child>
                            <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">15</property>
                                <child>
                                    <object class="GtkButton" id="finish_button">
                                        <property name="label">Einstellungen abschließen</property>
                                        <property name="halign">center</property>
                                        <style>
                                            <class name="suggested-action"/>
                                        </style>
                                    </object>
                                </child>
                                <child>
                                    <object class="GtkLabel">
                                        <property name="label">Alle erforderlichen Installationen werden ausgeführt, nachdem auf die Schaltfläche \'Fertigstellen\ angeklickt wurde.</property>
                                        <property name="wrap">true</property>
                                        <property name="justify">center</property>
                                        <style>
                                            <class name="body"/>
                                            <class name="dim-label"/>
                                        </style>
                                    </object>
                                </child>
                                <child>
                                    <object class="GtkLabel">
                                        <property name="label">Diese und weitere Optionen können später in den Einstellungen konfiguriert werden.</property>
                                        <property name="wrap">true</property>
                                        <property name="justify">center</property>
                                        <style>
                                            <class name="body"/>
                                            <class name="dim-label"/>
                                        </style>
                                    </object>
                                </child>
                            </object>
                        </child>
                    </object>
                </child>
            </object>
        </child>
    </object>
</interface>
